# Required for the summarizer and enhancer agent workflows.
OPENAI_API_KEY=

# Optional LangSmith tracing for LangChain/LangGraph runs and `langgraph deploy`.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=oas2mcp
LANGSMITH_WORKSPACE_ID=

# Optional only for self-hosted LangSmith.
LANGSMITH_ENDPOINT=

# Optional deployment naming for `langgraph deploy`.
LANGSMITH_DEPLOYMENT_NAME=oas2mcp

# Optional upstream auth for FastMCP bootstrap and live endpoint checks.
UPSTREAM_BEARER_TOKEN=
UPSTREAM_API_KEY=
UPSTREAM_API_KEY_HEADER=api_key
